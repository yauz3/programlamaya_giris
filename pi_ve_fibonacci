PSEUDO KOD: Pi / Fibonacci Menü Uygulaması

BAŞLA

FONKSİYON SecimAl():
    DÖNGÜ sonsuza kadar:
        kullanıcıdan "Pi için 1, Fibonacci için 2 seçin" girişi al
        EĞER giriş "1" veya "2" ise:
            SEÇİMİ tamsayıya çevir ve DÖNDÜR
        DEĞİLSE:
            "Hata: Lütfen 1 veya 2'yi seçin." yazdır

FONKSİYON NAl():
    DÖNGÜ sonsuza kadar:
        kullanıcıdan "N değerini girin" girişi al
        EĞER giriş tamsayıya çevrilebiliyorsa:
            N'i DÖNDÜR
        DEĞİLSE:
            "Hata: N bir tamsayı olmalı." yazdır

FONKSİYON NKontrolEt(N):
    EĞER N > 7 ise:
        "Lütfen {N} sayısını azaltınız." yazdır
        False DÖNDÜR
    AKSİ HALDE:
        True DÖNDÜR

FONKSİYON PiYazdir(N):
    Pi sayısını N ondalık basamakla formatla
    Formatlanmış Pi değerini yazdır

FONKSİYON FibonacciTopla(N):
    a = 0, b = 1, toplam = 0
    a <= N olduğu sürece:
        toplam = toplam + a
        (a, b) = (b, a + b)  // Fibonacci ilerlet
    toplamı DÖNDÜR

ANA PROGRAM (Main):
    secim = SecimAl()
    N = NAl()

    EĞER NKontrolEt(N) False ise:
        PROGRAMI BİTİR

    EĞER secim == 1 ise:
        PiYazdir(N)
    DEĞİLSE (secim == 2):
        toplam = FibonacciTopla(N)
        "Fibonacci toplamı: {toplam}" yazdır

BİTİR
